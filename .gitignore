# Dedicated public site repository: ignore everything by default.
*

# Allow repository metadata and deploy workflow.
!/.gitignore
!/README.md
!/.github/
!/.github/workflows/
!/.github/workflows/deploy-pages.yml
!/scripts/
!/scripts/**
!/IDEIAS/
/IDEIAS/*
!/IDEIAS/README.md

# Allow the published site source.
!/site/
!/site/**

# Ignore generated Jekyll output.
/site/_site/

# Ignore macOS metadata inside published assets.
**/.DS_Store
